            </if>
        </where>

    </select>


    <select id="getByStateList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM duration_order
        <where>

            <if test="stateList != null">
                state in
                <foreach collection="stateList" index="index" item="state" open="(" separator="," close=")">
                    #{state}
                </foreach>
            </if>

        </where>

    </select>

    <update id="updateInvalidByById" parameterType="java.lang.Long">

        update duration_order
        <set>
            state = 0
        </set>
        where id = #{id,jdbcType=BIGINT}
    </update>


    <select id="queryByOrderNoList" parameterType="list" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from duration_order a
        <where>

            <if test="list != null and list.size()>0">
                AND a.order_no IN
                <foreach item="item" index="index" collection="list" open="(" close=")" separator=",">
                    #{item}
                </foreach>
            </if>
        </where>
    </select>

