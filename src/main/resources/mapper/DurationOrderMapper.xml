    <select id="getDurationOrderJoinAdOrderListByState" parameterType="java.lang.Integer" resultMap="DurationOrderJoinAdOrderMap">
        select
        a.retention_time,a.order_no,a.user_no,a.device_no,
        b.machine_token,b.machine_name,b.machine_id,b.machine_key,b.product_no
        from duration_order a
        LEFT JOIN order_ad b
        ON a.order_no = b.order_no
        <where>
            and b.state =1
            <if test="state!=null">
                and a.state=#{state,jdbcType=TINYINT}
            </if>
        </where>
    </select>

