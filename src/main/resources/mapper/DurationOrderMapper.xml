    <select id="selectByList" parameterType="com.yunny.channel.common.query.ProductInfoDmmQuery" resultMap="BaseResultMap2">
        SELECT
        `do`.*,oa.machine_key,oa.machine_name
        FROM
        order_ad oa
        LEFT JOIN duration_order `do`
        ON oa.order_no = `do`.order_no
        <where>
            <if test="userNo!=null">
                AND oa.user_no = #{userNo}
            </if>
            <if test="channelNo!=null">
                AND do.channel_no = #{channelNo}
            </if>
            <!--查询未销毁的机器-->
            <if test="state!=null">
                AND do.state != #{state}
                and do.state !=4
            </if>
            <if test="deviceNo != null and deviceNo != ''">
                AND oa.device_no=#{deviceNo}
            </if>
            <if test="productNoList">
                AND do.product_no in
                <foreach collection="productNoList" item="productNo" index="index" open="(" separator="," close=")">
                    #{productNo}
                </foreach>
            </if>

        </where>
        order by update_time desc
        <if test="pageParameter != null">
            limit #{pageParameter.offset},#{pageParameter.pageSize}
        </if>
    </select>

    <select id="selectByListCount" parameterType="com.yunny.channel.common.query.ProductInfoDmmQuery" resultType="java.lang.Integer">
        SELECT
        count(*)
        FROM
        order_ad oa
        LEFT JOIN duration_order `do`
        ON oa.order_no = `do`.order_no
        <where>
            <if test="userNo!=null">
                AND oa.user_no = #{userNo}
            </if>
            <if test="channelNo!=null">
                AND do.channel_no = #{channelNo}
            </if>
            <if test="state!=null">
                AND do.state != #{state}
            </if>
            <if test="deviceNo != null and deviceNo != ''">
                AND oa.device_no=#{deviceNo}
            </if>
            <if test="productNoList!=null">
                AND do.product_no in
                <foreach collection="productNoList" item="productNo" index="index" open="(" separator="," close=")">
                    #{productNo}
                </foreach>
            </if>

        </where>

    </select>



