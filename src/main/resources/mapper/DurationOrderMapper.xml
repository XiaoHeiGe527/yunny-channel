        <result column="due_time" jdbcType="TIMESTAMP" property="dueTime" />

    </resultMap>


<!-- 查询到期时间小于等于指定时间的时长订单(到期时间小于当前MYsql now()函数 时间的) -->
    <select id="getByStateListAndDueTime" resultMap="GetByStateListAndDueTimeResultMap" parameterType="com.yunny.channel.common.query.DurationOrderQuery">

        SELECT
        a.user_no,a.order_no,b.mobile,a.due_time
        FROM
        duration_order a

        LEFT JOIN order_ad b

        ON a.order_no = b.order_no

        <where>

            b.state = 1
            and  a.due_time >now()

            <if test="dueTimeStr != null">
                and a.due_time  <![CDATA[<=]]>  #{dueTimeStr,jdbcType=TIMESTAMP}
            </if>

            <if test="stateList != null and stateList.size()>0">
                and  a.state in
                <foreach collection="stateList" index="index" item="state" open="(" separator="," close=")">
                    #{state}
                </foreach>
            </if>

        </where>

    </select>

