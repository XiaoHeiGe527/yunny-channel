    <select id="getByDeviceNo" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List_new"/>
        FROM duration_order
        <where>
            <if test="deviceNo!=null">
                and device_no=#{deviceNo,jdbcType=VARCHAR}
            </if>
        </where>

    </select>

    <select id="getByOrderNo" parameterType="java.lang.String" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM duration_order
        <where>
            state = 1
            <if test="orderNo!=null">
                and order_no=#{orderNo,jdbcType=VARCHAR}
            </if>
        </where>

    </select>


    <select id="getByOnlyOrder" parameterType="java.lang.String" resultMap="BaseResultMap">
