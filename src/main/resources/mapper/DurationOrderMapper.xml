            </if>
            <if test="productNo != null">
                product_no = #{productNo,jdbcType=TINYINT},
            </if>
            <if test="userNo != null">
                user_no = #{userNo,jdbcType=INTEGER},
            </if>
            <if test="resetTimes != null">
