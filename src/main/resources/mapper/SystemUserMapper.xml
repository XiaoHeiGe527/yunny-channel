            </if>

            <if test="mobile != null">
                and mobile = #{mobile,jdbcType=VARCHAR}
            </if>



        </where>
    </select>



    <!-- 根据roleId查询绑定的用户集合 -->
    <select id="getUsersByRoleId" parameterType="java.lang.Integer" resultType="com.yunny.channel.common.entity.SystemUserDO">
    select
        u.*  -- 查询用户表所有字段，对应SystemUserDO实体
    from
        system_user u
    inner join
        system_user_role ur on u.user_no = ur.user_no  -- 通过user_no关联
    where
        ur.role_id = #{roleId}  -- 筛选指定角色ID的关联记录
</select>




</mapper>