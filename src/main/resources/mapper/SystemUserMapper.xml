    <select id="selectByPrimaryKey" parameterType="com.yunny.channel.common.query.SystemUserQuery" resultMap="BaseResultMap">
        select

        <include refid="Base_Column_List" />
        from system_user
        <where>
            <if test="userNo != null">
                and user_no = #{userNo,jdbcType=VARCHAR}
            </if>
            <if test="loginName != null">
                and login_name = #{loginName,jdbcType=VARCHAR}
            </if>
            <if test="name != null">
