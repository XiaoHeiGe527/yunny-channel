<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.yunny.channel.mapper.FilePositionMapper" >

    <resultMap id="BaseResultMap" type="com.yunny.channel.common.entity.FilePositionDO">
             <id column="id" jdbcType="BIGINT" property="id"/>
             <id column="position_code" jdbcType="VARCHAR" property="positionCode"/>
             <id column="file_type" jdbcType="TINYINT" property="fileType"/>
             <id column="region" jdbcType="VARCHAR" property="region"/>
             <id column="cabinet_num" jdbcType="VARCHAR" property="cabinetNum"/>
             <id column="cabinet_level" jdbcType="TINYINT" property="cabinetLevel"/>
             <id column="remarks" jdbcType="VARCHAR" property="remarks"/>
             <id column="update_man" jdbcType="VARCHAR" property="updateMan"/>
             <id column="update_time" jdbcType="TIMESTAMP" property="updateTime"/>
             <id column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
            id,
            position_code,
            file_type,
            region,
            cabinet_num,
            cabinet_level,
            remarks,
            update_man,
            update_time,
            create_time
    </sql>

    <select id="listByQuery" parameterType="com.yunny.channel.common.query.FilePositionQuery" resultMap="BaseResultMap">
         select
         <include refid="Base_Column_List" />
         from file_position

        WHERE 1= 1

        <if test="fileType != null">
            and  file_type = #{fileType}
        </if>

        <if test="cabinetNum != null">
            and  cabinet_num = #{cabinetNum}
        </if>


        ORDER BY  id  asc

        <if test="pageParameter!=null">
            LIMIT #{pageParameter.offset}, #{pageParameter.pageSize}
        </if>
     </select>

     <select id="countByQuery" parameterType="com.yunny.channel.common.query.FilePositionQuery" resultType="java.lang.Long">
       select count(*) from file_position

         WHERE 1= 1

         <if test="fileType != null">
             and  file_type = #{fileType}
         </if>


         <if test="cabinetNum != null">
             and  cabinet_num = #{cabinetNum}
         </if>

     </select>

     <select id="getById" parameterType="java.lang.Long" resultMap="BaseResultMap">
         select
         <include refid="Base_Column_List" />
         from file_position
         where id = #{id}
    </select>


    <!-- 新增表file_position信息 -->
    <insert id="insertSelective" parameterType="com.yunny.channel.common.entity.FilePositionDO">
        insert into file_position
        <trim prefix="(" suffix=")" suffixOverrides=",">
                    <if test="positionCode != null and positionCode != ''">
                        position_code,
                    </if>
                    <if test="fileType != null">
                        file_type,
                    </if>
                    <if test="region != null and region != ''">
                        region,
                    </if>
                    <if test="cabinetNum != null and cabinetNum != ''">
                        cabinet_num,
                    </if>
                    <if test="cabinetLevel != null">
                        cabinet_level,
                    </if>
                    <if test="remarks != null and remarks != ''">
                        remarks,
                    </if>
                    <if test="updateMan != null and updateMan != ''">
                        update_man,
                    </if>
                    <if test="updateTime != null">
                        update_time,
                    </if>
                    <if test="createTime != null">
                        create_time,
                    </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
                <if test="positionCode != null and positionCode != ''">
                    #{positionCode},
                </if>
                <if test="fileType != null">
                    #{fileType},
                </if>
                <if test="region != null and region != ''">
                    #{region},
                </if>
                <if test="cabinetNum != null and cabinetNum != ''">
                    #{cabinetNum},
                </if>
                <if test="cabinetLevel != null">
                    #{cabinetLevel},
                </if>
                <if test="remarks != null and remarks != ''">
                    #{remarks},
                </if>
                <if test="updateMan != null and updateMan != ''">
                    #{updateMan},
                </if>
                <if test="updateTime != null">
                    #{updateTime},
                </if>
                <if test="createTime != null">
                    #{createTime},
                </if>
        </trim>
    </insert>


    <!-- 根据主键更新表信息 -->
    <update id="updateSelective" parameterType="com.yunny.channel.common.entity.FilePositionDO">
        UPDATE file_position
        <set>
                <if test="positionCode != null and positionCode != ''">
                    position_code = #{positionCode},
                </if>
                <if test="fileType != null">
                    file_type = #{fileType},
                </if>
                <if test="region != null and region != ''">
                    region = #{region},
                </if>
                <if test="cabinetNum != null and cabinetNum != ''">
                    cabinet_num = #{cabinetNum},
                </if>
                <if test="cabinetLevel != null">
                    cabinet_level = #{cabinetLevel},
                </if>
                <if test="remarks != null and remarks != ''">
                    remarks = #{remarks},
                </if>
                <if test="updateMan != null and updateMan != ''">
                    update_man = #{updateMan},
                </if>
                <if test="updateTime != null">
                    update_time = #{updateTime},
                </if>
                <if test="createTime != null">
                    create_time = #{createTime},
                </if>
        </set>
        where id = #{id}
    </update>




</mapper>