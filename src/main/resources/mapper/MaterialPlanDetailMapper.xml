             <id column="specification" jdbcType="VARCHAR" property="specification"/>
             <id column="quantity" jdbcType="INTEGER" property="quantity"/>
             <id column="unit" jdbcType="VARCHAR" property="unit"/>
             <id column="unit_price" jdbcType="DECIMAL" property="unitPrice"/>
             <id column="amount" jdbcType="DECIMAL" property="amount"/>
