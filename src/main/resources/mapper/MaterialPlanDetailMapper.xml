    <!-- 新增表material_plan_detail信息 -->
    <insert id="insertSelective" parameterType="com.yunny.channel.common.entity.MaterialPlanDetailDO">
        insert into material_plan_detail
        <trim prefix="(" suffix=")" suffixOverrides=",">
