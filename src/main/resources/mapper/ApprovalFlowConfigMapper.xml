<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.yunny.channel.mapper.ApprovalFlowConfigMapper" >

    <resultMap id="BaseResultMap" type="com.yunny.channel.common.entity.ApprovalFlowConfigDO">
             <id column="flow_id" jdbcType="INTEGER" property="flowId"/>
             <id column="flow_name" jdbcType="VARCHAR" property="flowName"/>
             <id column="plan_type" jdbcType="VARCHAR" property="planType"/>
             <id column="flow_desc" jdbcType="VARCHAR" property="flowDesc"/>
             <id column="flow_status" jdbcType="TINYINT" property="flowStatus"/>
             <id column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
            flow_id,
            flow_name,
            plan_type,
            flow_desc,
            flow_status,
            create_time
    </sql>

    <select id="listByQuery" parameterType="com.yunny.channel.common.query.ApprovalFlowConfigQuery" resultMap="BaseResultMap">
         select
         <include refid="Base_Column_List" />
         from approval_flow_config

         where  1 = 1

        <if test="flowStatus != null">
            and  flow_status = #{flowStatus}
        </if>


     </select>

     <select id="countByQuery" parameterType="com.yunny.channel.common.query.ApprovalFlowConfigQuery" resultType="java.lang.Long">
       select count(*) from approval_flow_config
     </select>



    <!-- 新增表approval_flow_config信息 -->
    <insert id="insertSelective" parameterType="com.yunny.channel.common.entity.ApprovalFlowConfigDO">
        insert into approval_flow_config
        <trim prefix="(" suffix=")" suffixOverrides=",">
                    <if test="flowId != null">
                        flow_id,
                    </if>
                    <if test="flowName != null and flowName != ''">
                        flow_name,
                    </if>
                    <if test="planType != null and planType != ''">
                        plan_type,
                    </if>
                    <if test="flowDesc != null and flowDesc != ''">
                        flow_desc,
                    </if>
                    <if test="flowStatus != null">
                        flow_status,
                    </if>
                    <if test="createTime != null">
                        create_time,
                    </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
                <if test="flowId != null">
                    #{flowId},
                </if>
                <if test="flowName != null and flowName != ''">
                    #{flowName},
                </if>
                <if test="planType != null and planType != ''">
                    #{planType},
                </if>
                <if test="flowDesc != null and flowDesc != ''">
                    #{flowDesc},
                </if>
                <if test="flowStatus != null">
                    #{flowStatus},
                </if>
                <if test="createTime != null">
                    #{createTime},
                </if>
        </trim>
    </insert>


    <!-- 根据主键更新表信息 -->
    <update id="updateSelective" parameterType="com.yunny.channel.common.entity.ApprovalFlowConfigDO">
        UPDATE approval_flow_config
        <set>
                <if test="flowId != null">
                    flow_id = #{flowId},
                </if>
                <if test="flowName != null and flowName != ''">
                    flow_name = #{flowName},
                </if>
                <if test="planType != null and planType != ''">
                    plan_type = #{planType},
                </if>
                <if test="flowDesc != null and flowDesc != ''">
                    flow_desc = #{flowDesc},
                </if>
                <if test="flowStatus != null">
                    flow_status = #{flowStatus},
                </if>
                <if test="createTime != null">
                    create_time = #{createTime},
                </if>
        </set>
    </update>


</mapper>