    <!-- 定义一个名为 batchUpdateVehiclesOutwardCard 的更新操作 -->
    <update id="batchUpdateVehiclesOutwardCard" parameterType="java.util.List">
        <!-- 指定要更新的表为 vehicles_outward_card -->
        UPDATE vehicles_outward_card
        <!-- 使用 SET 关键字来设置要更新的字段 -->
        SET
        <!-- 对 state 字段进行更新，使用 CASE WHEN 语句实现动态更新 -->
        state = CASE
        <!-- 开始遍历传入的列表参数 -->
        <foreach collection="list" item="item" separator=" ">
            <!-- 对于列表中的每个元素，生成一个 WHEN 子句 -->
            <!-- 当 card_no 字段的值等于当前元素的 cardNo 属性时 -->
            WHEN card_no = #{item.cardNo} THEN
            <!-- 将 state 字段更新为当前元素的 state 属性值 -->
            #{item.state}
        </foreach>
        <!-- 如果 card_no 不匹配列表中的任何元素，则保持 state 字段的原值 -->
        ELSE state
        <!-- CASE 语句结束 -->
        END
        <!-- 使用 WHERE 子句来筛选要更新的记录 -->
        WHERE
        <!-- 筛选条件为 card_no 字段的值在一个集合中 -->
        card_no IN
        <!-- 开始遍历传入的列表参数，生成 IN 子句的集合 -->
        <foreach collection="list" item="item" open="(" separator="," close=")">
            <!-- 将列表中每个元素的 cardNo 属性值添加到集合中 -->
            #{item.cardNo}
            <!-- IN 子句的集合生成结束 -->
        </foreach>
        <!-- 更新操作定义结束 -->
    </update>
