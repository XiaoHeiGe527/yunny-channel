    <select id="listByQuery" parameterType="com.yunny.channel.common.query.VehiclesOutwardCardQuery" resultMap="BaseResultListMap">
        SELECT
        a.id,
        a.card_no,
        a.car_number,
        b.car_type,
        c.name,
        a.days_remaining,
        a.open_date,
        a.warning_time,
        a.expiration_date,
        a.state,
        b.active_state,
        a.remarks,
        a.update_man,
        a.update_time,
        a.create_time
        FROM
        vehicles_outward_card a
        LEFT JOIN  company_vehicles b
        ON a.car_number = b.car_number
        LEFT JOIN vehicle_customers c
        ON a.vehicle_customers_id = c.id

        WHERE 1= 1


        <if test="expiryAlert != null and  expiryAlert != ''">
            and  a.warning_time &lt;= #{expiryAlert}
        </if>

        <if test="openDateDateStart != null and  openDateDateStart != ''">
            AND a.open_date <![CDATA[>=]]>  #{openDateDateStart}
        </if>
        <if test="openDateDateEnd != null and  openDateDateEnd != ''" >
            AND a.open_date <![CDATA[<=]]>  #{openDateDateEnd}
        </if>

        <if test="vehicleCustomersName != null and  vehicleCustomersName != ''">
            and  c.name like  "%"#{vehicleCustomersName,jdbcType=VARCHAR}"%"
        </if>

        <if test="carNumber != null and  carNumber != ''">
            and a.car_number like  "%"#{carNumber,jdbcType=VARCHAR}"%"
        </if>

        <if test="carType != null">
            and  b.car_type = #{carType}
        </if>

        <if test="activeState != null">
            and  b.active_state = #{activeState}
        </if>

        <if test="state != null">
            and    a.state = #{state}
        </if>

        order by a.warning_time asc

        <if test="pageParameter!=null">
            /*pageParameter xml分页*/
            LIMIT #{pageParameter.offset}, #{pageParameter.pageSize}
        </if>

     </select>

